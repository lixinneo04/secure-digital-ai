# --- Google Cloud & AI Configuration ---
# Get your API key from https://aistudio.google.com/
GOOGLE_GENAI_API_KEY=your_api_key_here

# Your Google Cloud Project ID (e.g., gdg-hackathon-2026-xxxxxx)
GCP_PROJECT_ID=your_project_id_here

# --- Database Configuration ---
# Connection string for your MongoDB Atlas cluster
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/secure_digital

# --- Optional Plugin Settings ---
# Set to 'dev' for Genkit Developer UI telemetry
GENKIT_ENV=dev
