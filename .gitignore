# --- Environment / Secrets ---
# Crucial for security - keeps your API keys out of GitHub history
.env
.env.local
.env.*.local

# --- Dependencies ---
# These are large and should be installed via 'npm install' by your teammates
node_modules/
jspm_packages/

# --- Build & Output ---
# Compiled JavaScript and build logs
dist/
lib/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Genkit Specifics ---
# Local database for traces and temporary runtimes
.genkit/
genkit-traces.db

# --- OS / Editor Specifics ---
# Hidden system files and local IDE settings
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
